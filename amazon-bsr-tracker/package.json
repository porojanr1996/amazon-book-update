{
  "name": "amazon-bsr-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Amazon Best Sellers Rank tracker with Node.js, TypeScript, Playwright",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "scrape": "npm run scrape --workspace=@bsr-tracker/api",
    "scrape:all": "npm run scrape:all --workspace=@bsr-tracker/api",
    "diagnose": "npm run diagnose --workspace=@bsr-tracker/ai-diagnostics",
    "db:generate": "npm run generate --workspace=@bsr-tracker/db",
    "db:migrate": "npm run migrate --workspace=@bsr-tracker/db",
    "db:studio": "npm run studio --workspace=@bsr-tracker/db"
  },
  "devDependencies": {
    "turbo": "^1.11.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
